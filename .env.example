VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# ─── Authed smoke tests (optional) ──────────────────────────────────────────
# Required only if you run the Pro-flow smoke suite (`npm run test:smoke`
# project `pro-chromium`). These should point at a dedicated test account
# in Supabase whose `profiles` row has subscription_tier='pro' and
# subscription_status='active'. Set the flags directly via SQL — no Stripe
# subscription needed.
#
# Setup:
#   1. Sign up a fresh account in your app (e.g. smoke-test@tractova.com)
#   2. In Supabase SQL editor:
#        update profiles
#           set subscription_tier='pro',
#               subscription_status='active'
#         where id = (select id from auth.users where email='smoke-test@tractova.com');
#   3. Drop the credentials below into your local .env.local
#
# TEST_USER_EMAIL=smoke-test@tractova.com
# TEST_USER_PASSWORD=your_test_password
