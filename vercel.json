{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/lens-insight.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/send-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/send-alerts",
      "schedule": "0 14 * * 1,4"
    },
    {
      "path": "/api/refresh-ix-queue",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/refresh-substations",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/check-staleness",
      "schedule": "0 8 * * 1"
    }
  ]
}
