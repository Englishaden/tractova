{
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/lens-insight.js": {
      "maxDuration": 60
    },
    "api/refresh-data.js": {
      "maxDuration": 300
    },
    "api/refresh-substations.js": {
      "maxDuration": 60
    },
    "api/refresh-ix-queue.js": {
      "maxDuration": 60
    },
    "api/refresh-capacity-factors.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/send-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/send-alerts",
      "schedule": "0 14 * * 1,4"
    },
    {
      "path": "/api/refresh-ix-queue",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/refresh-substations",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/check-staleness",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/refresh-capacity-factors",
      "schedule": "0 7 1 1,4,7,10 *"
    },
    {
      "path": "/api/refresh-data?source=fast",
      "schedule": "0 7 * * 0"
    },
    {
      "path": "/api/refresh-data?source=nmtc_lic",
      "schedule": "30 7 * * 0"
    }
  ]
}
