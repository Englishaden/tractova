# Claude Code internal — gitignore everything inside .claude/ EXCEPT
# the project-shared settings.json (deny rules + hooks for safety net
# per CLAUDE.md). User-specific settings.local.json stays out.
# Note: this uses .claude/* (contents) not .claude/ (directory) so the
# whitelist for settings.json is reachable.
.claude/*
!.claude/settings.json
claude.exe

# Local notes / scratch files (not meant for the repo)
Genuinely useful for the consultant.txt
# Marketing / GTM plan — contains COI analysis specific to Nexamp + Ameresco;
# stays local-only, never commits to GitHub.
Marketing-Outreach-Plan.md
.logs/

# Playwright artifacts (smoke test outputs)
/test-results/
/playwright-report/
/playwright/.cache/
# Persisted Pro-user session for authed smoke tests — never commit
tests/.auth/

# Large public-dataset reference files (>100 MB GitHub limit). Keep locally
# for parsing scripts; never commit. LBNL TTS CSV is ~1.9 GB.
public/TTS_LBNL_public_file_*.csv
public/Lazard*.pdf

# Manual Supabase snapshots from scripts/dump-supabase-snapshot.mjs.
# Stay local; never commit DB content.
backups/
