{
  "name": "tractova",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:smoke": "playwright test --project=chromium",
    "test:mobile": "playwright test --project=mobile",
    "test:mobile:pro": "playwright test --project=setup --project=mobile-pro",
    "test:smoke:pro": "playwright test --project=setup --project=pro-chromium",
    "test:smoke:all": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint:api": "node scripts/lint-api.mjs",
    "lint:citations": "node scripts/lint-citations.mjs",
    "lint:secrets": "node scripts/lint-secrets.mjs",
    "lint:audit": "node scripts/audit-check.mjs",
    "verify": "npm run lint:api && npm run lint:citations && npm run lint:secrets && npm run lint:audit && npm run test:unit && npm run build && npm run test:smoke",
    "verify:full": "npm run lint:api && npm run lint:citations && npm run lint:secrets && npm run lint:audit && npm run test:unit && npm run build && npm run test:smoke:all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.4.1",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.12.7",
    "shadcn": "^4.7.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "us-atlas": "^3.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
